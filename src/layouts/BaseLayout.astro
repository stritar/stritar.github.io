---
interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  canonicalUrl?: string;
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    author: string;
  };
}

const SITE_NAME = 'Denis Stritar';
const SITE_URL = 'https://denisstritar.com';
const DEFAULT_TITLE = 'Denis Stritar — Product Designer';
const DEFAULT_DESCRIPTION = 'Portfolio and selected work of Denis Stritar, product designer.';

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogType = 'website',
  ogImage,
  canonicalUrl,
  article,
} = Astro.props;

const resolvedCanonical = canonicalUrl
  ? new URL(canonicalUrl).href
  : new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;

const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.site ?? SITE_URL).href
  : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

    {article && <meta property="article:published_time" content={article.publishedTime} />}
    {article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
    {article && <meta property="article:author" content={article.author} />}

    {/* TODO: generate and add favicon suite (ico, svg light/dark, apple-touch-icon, 192/512 PNG). */}
    {/* <link rel="icon" href="/favicon.ico" sizes="32x32" /> */}
    {/* <link rel="icon" href="/favicon.svg" type="image/svg+xml" /> */}
    {/* <link rel="apple-touch-icon" href="/apple-touch-icon.png" /> */}
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site summary" />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
  }
  .skip-link:focus {
    left: 0;
    padding: 0.5rem 1rem;
    background: #000;
    color: #fff;
    z-index: 1000;
  }
</style>
